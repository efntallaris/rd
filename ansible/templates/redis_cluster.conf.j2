port {{ master_port }}
cluster-enabled yes
daemonize yes
maxclients 100000
cluster-node-timeout 9000
cluster-require-full-coverage no
bind 0.0.0.0
protected-mode no
appendonly no
dir {{ redis_data_dir }}
dbfilename {{ inventory_hostname }}.rdb
cluster-config-file nodes-{{ inventory_hostname }}-{{ master_port }}.conf
logfile {{ redis_log_dir }}/{{ inventory_hostname }}__
{% if redis_variant | default('custom') == 'custom' %}
# Aqueduct fork: dbAdd populates r_allocator (slot-keyed memory pool with
# pre-registered RDMA MRs) implicitly — the legacy cluster-rdma-allocator-shadow
# config knob was removed; r_allocator is now the only kvobj allocator for
# cluster-mode string adds (gated by cluster_enabled || rdma_migration_redisraft_mode).
cluster-rdma-allocator-skip-lock {{ "yes" if (rdma_allocator_skip_lock | default(false) | bool) else "no" }}
# Aqueduct TRANSFER/BACKPATCH overlap: donor sends DONE-SLOTS-INIT upfront
# then pipelined DONE-SLOTS-CHUNK every K slots, so recipient backpatch
# starts in parallel with the remaining RDMA-WRITEs.
cluster-rdma-transfer-overlap {{ "yes" if (rdma_transfer_overlap | default(true) | bool) else "no" }}
cluster-rdma-transfer-chunk-slots {{ rdma_transfer_chunk_slots | default(32) }}
# Aqueduct slot-state machine: wrap GET / GETEX replies in
# [state, peer_endpoint, value] so cooperative clients (e.g. the YCSB
# driver in ycsb_client/) can drive client-side double reads during
# migration and skip the MOVED/ASK topology refresh storm. Off by default
# upstream; on for the custom_reshard_v2 experiment.
slot-meta-reply {{ "yes" if (slot_meta_reply | default(true) | bool) else "no" }}
# Phase B.5 chain replication: recipient leader's chain followers (the other
# 2 vanilla-cluster nodes in the migration-target replica set). On the
# recipient leader (redis3) this is "redis4:8000 ycsb1:8000". On the
# follower nodes this is empty — they don't initiate chain establishment,
# only respond to CHAIN-PREP/WIRE/FORWARDED RPCs.
rdma-chain-followers "{{ rdma_chain_followers | default('') }}"
rdma-chain-pool-bytes {{ rdma_chain_pool_bytes | default(67108864) }}
{% endif %}
save ""
